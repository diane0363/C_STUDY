{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: gcc.exe build and run (UTF-8 Output Fix)",
            // ⭐⭐⭐ COMMAND 문자열에 모든 옵션을 한 번만 넣습니다. ⭐⭐⭐
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe -fdiagnostics-color=never -g -finput-charset=utf-8 -fexec-charset=CP949 \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\" && \"${fileDirname}\\${fileBasenameNoExtension}.exe\"",
            "args": [], // ⭐⭐⭐ args 배열은 비워둡니다. ⭐⭐⭐
            "options": {
                "cwd": "${fileDirname}",
                "env": {
                    "LANG": "C.UTF-8", // MINGW/Git Bash 환경 인코딩 설정
                    "LC_CTYPE": "C.UTF-8"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "GCC 빌드, 실행 및 UTF-8/CP949 인코딩 설정"
        },
        // (두 번째 작업은 그대로 유지해도 됩니다.)
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file (Default)",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=never",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                // 만약 기본 빌드(실행하지 않는) 시에도 한글 오류가 있다면 여기에 추가
                "-fexec-charset=CP949"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}